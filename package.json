{
  "name": "deploy-ef-core-migration",
  "version": "3.0.0",
  "private": true,
  "description": "GitHub Action to deploy Entity Framework Core migrations from a DLL",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test",
    "upgrade-dependencies": "npx npm-check-updates -u && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benday-inc/deploy-ef-core-migration.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "Benjamin Day Consulting, Inc.",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "which": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
